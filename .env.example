# iSATPrep environment variables (Vite).
#
# Copy this file to `.env` and fill in real values to enable Firebase + GA.
# WITHOUT these set, the site runs in "no-op" mode: Firebase does not initialize
# and the current FAKE auth / no-analytics behavior is preserved. The build works
# fine with everything below left blank.
#
# Only variables prefixed with VITE_ are exposed to client code (import.meta.env).
# NOTE: Firebase web config keys are NOT secrets — they are safe to ship in the
# client bundle. Access is controlled by Firebase Security Rules, not by hiding
# the apiKey. Real secrets must never go in a VITE_ variable.

# --- Firebase web app config (wired up in a later auth task) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# --- Google Analytics (wired up in a later consent/GA task) ---
VITE_GA_MEASUREMENT_ID=

# --- Firebase App Check (Phase 2B) — reCAPTCHA v3/Enterprise site key ---
# Leave blank until you create the key in the Firebase console; App Check is
# skipped entirely while blank, so the app keeps working.
VITE_APPCHECK_SITE_KEY=
